# ---- Copy to .env and fill in values ----

# --- API server ---
API_HTTP_ADDR=:8080
API_ENV=local
API_LOG_LEVEL=debug

# Comma-separated list of allowed origins for CORS. Single web app on :3000.
API_CORS_ORIGINS=http://localhost:3000

# --- Postgres ---
POSTGRES_HOST=localhost
# 5432 is the native Postgres; 5433 is the ibms-postgres container; use 5434.
POSTGRES_PORT=5434
POSTGRES_USER=projectx
POSTGRES_PASSWORD=projectx_dev
POSTGRES_DB=projectx
POSTGRES_SSLMODE=disable

# --- Auth (super admin) ---
# Use a long random string. Rotated independently per environment.
JWT_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_TTL_HOURS=24

# Seeded super admin (used by `make seed-admin`). Change before first run.
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMeNow!2026

# Cookie config (leave Secure=false in local; set true in prod over HTTPS)
COOKIE_NAME=px_session
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# --- Public form ---
# Base URL where the web app serves /l/<studio-slug>/<campaign-slug>. Used to
# render shareable links in the admin UI.
PUBLIC_FORM_BASE_URL=http://localhost:3000

# --- Google Sheets integration ---
# Path (relative to apps/api or absolute) to the service-account credentials JSON.
# See docs/SETUP_GOOGLE_SHEETS.md for the provisioning steps.
GOOGLE_CREDENTIALS_PATH=secrets/google-credentials.json

# The spreadsheet ID (from the sheet URL between /d/ and /edit).
GOOGLE_SHEETS_ID=

# The worksheet/tab name to append to (default "Leads").
GOOGLE_SHEETS_TAB=Leads

# --- Frontend (Next.js web app) ---
# Internal address of the Go API. The browser never sees this — Next.js rewrites
# `/api/*` (relative) to this URL, and server-side RSC fetches use it directly.
# Set in apps/web/.env.local — kept here for reference.
API_BASE_URL=http://localhost:8080
